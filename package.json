{
  "name": "stackhand",
  "version": "1.0.0",
  "description": "Personal Docker/YAML stack manager",
  "private": true,
  "type": "commonjs",
  "license": "UNLICENSED",
  "scripts": {
    "============ FIRST TIME ============": "",
    "setup": "bash scripts/setup.sh",
    "env:setup": "bash scripts/env-setup.sh",
    "============ DEVELOPMENT ============": "",
    "dev": "npm run kill:ports && npm run dev:db:sync && DATABASE_URL=\"file:./workspaces-data/dev.db\" NODE_ENV=development concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "nest start --watch",
    "dev:frontend": "cd client && npm run dev",
    "dev:db:sync": "DATABASE_URL=\"file:./workspaces-data/dev.db\" npx prisma db push --accept-data-loss",
    "============ PRODUCTION ============": "",
    "start": "bash scripts/start-production.sh",
    "stop": "bash scripts/stop.sh",
    "restart": "bash scripts/restart.sh",
    "update": "bash scripts/update.sh",
    "install": "sudo bash scripts/install-service.sh",
    "uninstall": "sudo bash scripts/uninstall.sh",
    "============ BUILD ============": "",
    "build": "nest build && npm run build:frontend",
    "build:frontend": "cd client && npm run build",
    "============ DATABASE ============": "",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "bash scripts/db-reset.sh",
    "============ UTILITY ============": "",
    "kill:ports": "fuser -k ${PORT:-22443}/tcp 2>/dev/null; fuser -k ${FRONTEND_PORT:-22080}/tcp 2>/dev/null; true",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "clean": "bash scripts/clean.sh"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.27",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.1.3",
    "@nestjs/websockets": "^11.0.16",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^11.10.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.8.1",
    "dockerode": "^4.0.5",
    "helmet": "^8.2.0",
    "js-yaml": "^4.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/compression": "^1.8.1",
    "@types/dockerode": "^4.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.0.0",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
