#!/usr/bin/env bash
set -e

STACKHAND_SRC="${STACKHAND_DIR:-$HOME/.local/share/stackhand/src}"
PID_FILE="$STACKHAND_SRC/stackhand.pid"
LOG_FILE="$STACKHAND_SRC/stackhand.log"

case "${1:-help}" in
  start)
    if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
      echo "Stackhand is already running (PID: $(cat "$PID_FILE"))"
      exit 0
    fi
    if [ ! -f "$STACKHAND_SRC/dist/main.js" ]; then
      echo "Build not found. Run 'stackhand install' first."
      exit 1
    fi
    cd "$STACKHAND_SRC"
    nohup node dist/main.js >> "$LOG_FILE" 2>&1 &
    echo $! > "$PID_FILE"
    echo "Stackhand started (PID: $(cat "$PID_FILE"))"
    echo "Web UI: http://localhost:${PORT:-22443}"
    ;;
  stop)
    if [ -f "$PID_FILE" ]; then
      pid=$(cat "$PID_FILE")
      kill "$pid" 2>/dev/null && echo "Stackhand stopped" || echo "Not running"
      rm -f "$PID_FILE"
    else
      echo "Stackhand is not running"
    fi
    ;;
  restart)
    "$0" stop
    sleep 1
    "$0" start
    ;;
  status)
    if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
      echo "Stackhand is running (PID: $(cat "$PID_FILE"))"
    else
      echo "Stackhand is not running"
    fi
    ;;
  logs)
    if [ ! -f "$LOG_FILE" ]; then
      echo "No logs yet."
      exit 1
    fi
    tail -f "$LOG_FILE"
    ;;
  install)
    if [ ! -d "$STACKHAND_SRC" ]; then
      echo "Error: STACKHAND_DIR ($STACKHAND_SRC) does not exist."
      echo "Run install.sh first to set up the project."
      exit 1
    fi
    cd "$STACKHAND_SRC"
    echo "[1/5] Installing backend dependencies..."
    npm install
    echo "[2/5] Installing frontend dependencies..."
    cd client && npm install && cd ..
    echo "[3/5] Generating Prisma client..."
    npx prisma generate
    echo "[4/5] Running database migrations..."
    npx prisma migrate deploy
    echo "[5/5] Building project..."
    npm run build
    "$0" restart
    echo "Stackhand installed successfully!"
    echo "Run 'stackhand start' to launch."
    ;;
  update)
    echo "Updating stackhand (rebuild from current source)..."
    "$0" install
    ;;
  env)
    if [ -f "$STACKHAND_SRC/.env" ]; then
      cat "$STACKHAND_SRC/.env"
    else
      echo "No .env file found at $STACKHAND_SRC/.env"
    fi
    ;;
  *)
    echo "Stackhand — Personal Docker/YAML stack manager"
    echo ""
    echo "Usage: stackhand <command>"
    echo ""
    echo "Commands:"
    echo "  start       Start the server"
    echo "  stop        Stop the server"
    echo "  restart     Restart the server"
    echo "  status      Check if the server is running"
    echo "  logs        Tail server logs"
    echo "  install     Reinstall dependencies and rebuild"
    echo "  update      Rebuild + restart (same as install)"
    echo "  env         Show current environment variables"
    ;;
esac
