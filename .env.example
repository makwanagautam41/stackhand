# API authentication token (required for all /api routes)
STACKHAND_API_TOKEN=your-secret-token-here

# Backend API port
PORT=22443

# Frontend dev server port
FRONTEND_PORT=22080

# Backend bind host
HOST=0.0.0.0

# Optional explicit backend origin for the frontend dev proxy
# STACKHAND_BACKEND_ORIGIN=http://127.0.0.1:4000

# Default workspace root folder path (used by seed script)
DEFAULT_WORKSPACE_ROOT=/home/user/stackhand-data

# Ollama local API endpoint
OLLAMA_BASE_URL=http://localhost:11434

# SQLite database paths
#   PRODUCTION:  absolute path (persistent, outside project)
#   DEVELOPMENT: relative path (local to project, can be deleted freely)
# shell 'stackhand dev' overrides this to file:./workspaces-data/dev.db
# shell 'stackhand prod' uses whatever is in .env
DATABASE_URL="file:./workspaces-data/stackhand.db"

# Tavily Search API (1,000 free queries/month — no credit card — https://tavily.com/)
# Primary search provider.
TAVILY_API_KEY=tvly-your-api-key-here

# Brave Search API (free tier: ~2,000 queries/month — https://brave.com/search/api/)
BRAVE_SEARCH_API_KEY=your-brave-search-api-key

# Google Custom Search API (100 queries/day free — https://console.cloud.google.com/apis/credentials)
# Also needs a Search Engine ID: https://programmablesearchengine.google.com/
GOOGLE_API_KEY=
GOOGLE_CX=
