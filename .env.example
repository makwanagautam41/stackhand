# =============================================================================
# Stackhand — Environment Configuration
# =============================================================================
# Copy this to .env and fill in your values.
# The same .env file works for both development and production modes.
#   npm run dev  → NODE_ENV=development (uses dev.db, watch mode)
#   npm start    → NODE_ENV=production  (uses stackhand.db, compiled)
# =============================================================================

# -- API Authentication (REQUIRED) -------------------------------------------
# Used for all /api/* routes. Generate one via: openssl rand -hex 32
STACKHAND_API_TOKEN=your-secret-token-here

# -- Server Configuration ----------------------------------------------------
PORT=22443
FRONTEND_PORT=22080
HOST=0.0.0.0
NODE_ENV=production

# -- Database (SQLite) -------------------------------------------------------
# Production database path
DATABASE_URL="file:./workspaces-data/stackhand.db"
# Dev overrides this automatically via: npm run dev
# DATABASE_URL_DEV="file:./workspaces-data/dev.db"

# -- Workspace ---------------------------------------------------------------
DEFAULT_WORKSPACE_ROOT=/home/user/.local/share/stackhand/workspaces

# -- Ollama AI (optional) ----------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434

# -- Search APIs (optional) --------------------------------------------------
# Tavily Search API (https://tavily.com) — 1,000 free queries/month
TAVILY_API_KEY=tvly-your-api-key-here
# Brave Search API (https://brave.com/search/api/) — ~2,000 free queries/month
BRAVE_SEARCH_API_KEY=
# Google Custom Search API (https://developers.google.com/custom-search)
GOOGLE_API_KEY=
GOOGLE_CX=
