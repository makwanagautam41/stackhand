# API authentication token (required for all /api routes)
STACKHAND_API_TOKEN=your-secret-token-here

# Backend API port
PORT=22443

# Frontend dev server port
FRONTEND_PORT=22080

# Backend bind host
HOST=0.0.0.0

# Optional explicit backend origin for the frontend dev proxy
# STACKHAND_BACKEND_ORIGIN=http://127.0.0.1:4000

# Default workspace root folder path (used by seed script)
DEFAULT_WORKSPACE_ROOT=/home/user/stackhand-data

# Ollama local API endpoint
OLLAMA_BASE_URL=http://localhost:11434

# SQLite database path (relative to project root)
DATABASE_URL="file:./workspaces-data/stackhand.db"
